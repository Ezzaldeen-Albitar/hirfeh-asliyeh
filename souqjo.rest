Authorization: Bearer {{artisanToken}}
Content-Type: multipart/form-data; boundary=boundary

--boundary
Content-Disposition: form-data; name="images"; filename="img1.jpg"
Content-Type: image/jpeg

< ./img1.jpg
--boundary--

